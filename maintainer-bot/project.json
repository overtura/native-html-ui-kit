{
  "schemaVersion": 1,
  "controlPlane": "okorion/self-improving-maintainer-bot",
  "name": "Native HTML UI Kit",
  "kind": "html-css-only-native-ui-kit",
  "runtime": "Static HTML + CSS + Vite build only",
  "language": "ko",
  "goal": "브라우저 네이티브 HTML UI 기능을 밝은 no-JS UI kit로 축적하고, 중앙 maintainer bot이 PR 단위로 컴포넌트 예제와 문서를 개선한다.",
  "automation": {
    "defaultRiskLevel": "R1",
    "maxAutoMergeRiskLevel": "R1",
    "r3Mode": "draft_or_proposal_only",
    "autoMerge": false,
    "verifyCommands": [
      "pnpm install --frozen-lockfile || pnpm install",
      "pnpm check"
    ],
    "allowPaths": [
      "README.md",
      "DESIGN.md",
      "docs/**",
      "maintainer-bot/**",
      "index.html",
      "styles.css",
      "design-system/**"
    ],
    "denyPaths": [
      ".github/workflows/**",
      "CODEOWNERS",
      ".env*",
      ".npmrc",
      "src/**",
      "scripts/**",
      "infra/**",
      "terraform/**",
      "k8s/**",
      "migrations/**",
      "**/*.js",
      "**/*.ts",
      "*.pem",
      "*.key"
    ],
    "maxFiles": 10,
    "maxLines": 250
  }
}
