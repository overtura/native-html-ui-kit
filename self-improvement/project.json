{
  "name": "Native HTML UI Kit",
  "kind": "html-css-only-native-ui-kit",
  "runtime": "Static HTML + CSS + Vite build only",
  "language": "ko",
  "goal": "브라우저 네이티브 HTML UI 기능을 밝은 no-JS UI kit로 축적하고, 자동 PR로 컴포넌트 예제와 문서를 개선한다.",
  "allowedChangeScope": [
    "index.html",
    "styles.css",
    "design-system/**",
    "DESIGN.md",
    "README.md",
    "docs/**",
    ".github/workflows/**",
    ".github/prompts/**",
    "self-improvement/**",
    "scripts/**",
    "package.json"
  ],
  "blockedChangeScope": [
    "src/**",
    ".env*",
    "*.pem",
    "*.key",
    ".npmrc",
    "런타임 JavaScript",
    "실제 API key 또는 credential"
  ],
  "qualityGates": [
    "pnpm self-improve:guard",
    "pnpm check"
  ]
}
